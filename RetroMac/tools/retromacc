#!/usr/bin/env bash
# retromacc -- compiles classic Mac Toolbox C sources against the
# RetroMac runtime and packages the result as a double-clickable
# modern macOS .app bundle.
#
# Usage: retromacc <source.c> [<source.c> ...] [<resource.r> ...] -o <AppName>[.app]
#
# .r files are compiled as resources (Phase 2, see Toolbox.md) --
# listed explicitly, not auto-detected by matching basename against a
# .c file. That matters: this repo has a stale, unrelated demo.r left
# over from before RetroMac existed, which happens to share demo.c's
# basename purely by naming coincidence -- auto-detecting it would
# silently (and wrongly) try to compile it into demo.app's resources.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RETROMAC_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

SOURCES=()
RSRC_SOURCES=()
OUT_NAME=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -o)
            OUT_NAME="${2:-}"
            shift 2
            ;;
        -h|--help)
            echo "usage: retromacc <source.c> [more.c ...] [resource.r ...] -o <AppName>"
            exit 0
            ;;
        *.r)
            RSRC_SOURCES+=("$1")
            shift
            ;;
        *)
            SOURCES+=("$1")
            shift
            ;;
    esac
done

if [[ ${#SOURCES[@]} -eq 0 || -z "$OUT_NAME" ]]; then
    echo "usage: retromacc <source.c> [more.c ...] [resource.r ...] -o <AppName>" >&2
    exit 1
fi

OUT_NAME="${OUT_NAME%.app}"
APP_DIR="${OUT_NAME}.app"
CONTENTS_DIR="$APP_DIR/Contents"
MACOS_DIR="$CONTENTS_DIR/MacOS"
BIN_NAME="$(basename "$OUT_NAME")"

TMP_DIR="$(mktemp -d)"
trap 'rm -rf "$TMP_DIR"' EXIT

CLANG_FLAGS=(-fobjc-arc -Wall -Wno-unused-parameter -I "$RETROMAC_ROOT/include")

RUNTIME_SOURCES=(
    "$RETROMAC_ROOT/src/QuickDraw.c"
    "$RETROMAC_ROOT/src/MacRoman.c"
    "$RETROMAC_ROOT/src/WindowManager.c"
    "$RETROMAC_ROOT/src/MenuManager.c"
    "$RETROMAC_ROOT/src/ControlManager.c"
    "$RETROMAC_ROOT/src/EventManager.c"
    "$RETROMAC_ROOT/src/MiscManagers.c"
    "$RETROMAC_ROOT/src/TextEditManager.c"
    "$RETROMAC_ROOT/src/DialogManager.c"
    "$RETROMAC_ROOT/src/ResourceManager.c"
    "$RETROMAC_ROOT/src/CocoaBridge.m"
    "$RETROMAC_ROOT/src/AppShell.m"
)

OBJS=()

# User sources: rewrite "\p..." Pascal-string literals into plain C,
# then compile with -Dmain=RetroMacUserMain so AppShell.m can own the
# real process main() and boot Cocoa before the classic app's own
# event loop starts.
for src in "${SOURCES[@]}"; do
    base="$(basename "$src")"
    rewritten="$TMP_DIR/rw_${base}"
    python3 "$SCRIPT_DIR/pstr_rewrite.py" "$src" "$rewritten"

    obj="$TMP_DIR/${base}.o"
    echo "compiling $src"
    clang "${CLANG_FLAGS[@]}" -Dmain=RetroMacUserMain -c "$rewritten" -o "$obj"
    OBJS+=("$obj")
done

# Runtime sources: compiled as-is (AppShell.m's main() must stay main()).
for src in "${RUNTIME_SOURCES[@]}"; do
    base="$(basename "$src")"
    obj="$TMP_DIR/rt_${base}.o"
    clang "${CLANG_FLAGS[@]}" -c "$src" -o "$obj"
    OBJS+=("$obj")
done

mkdir -p "$MACOS_DIR"

clang -fobjc-arc "${OBJS[@]}" \
    -framework Cocoa -framework CoreText -framework CoreGraphics \
    -o "$MACOS_DIR/$BIN_NAME"

# Phase 2: any .r files passed on the command line are compiled with
# the real system Rez (present via Xcode or just the Command Line
# Tools -- `xcrun` finds whichever is active) into a flat, single-file
# resource blob (`-useDF`: no HFS+ resource-fork/xattr involved) and
# embedded as Contents/Resources/Resources.rsrc, which AppShell.m loads
# at boot. No .r file passed -- as with every Phase 0/1 sample -- and
# this whole block is skipped entirely.
if [[ ${#RSRC_SOURCES[@]} -gt 0 ]]; then
    SDK_PATH="$(xcrun --show-sdk-path)"
    REZ_INCLUDES=(
        -i "$RETROMAC_ROOT/rez"
        -i "$SDK_PATH/System/Library/Frameworks/Carbon.framework/Versions/A/Frameworks/HIToolbox.framework/Versions/A/Headers"
        -i "$SDK_PATH/System/Library/Frameworks/CoreServices.framework/Versions/A/Frameworks/CarbonCore.framework/Versions/A/Headers"
        -i "$SDK_PATH/System/Library/Frameworks/ApplicationServices.framework/Versions/A/Frameworks/HIServices.framework/Versions/A/Headers"
    )
    RESOURCES_DIR="$CONTENTS_DIR/Resources"
    mkdir -p "$RESOURCES_DIR"
    echo "compiling resources: ${RSRC_SOURCES[*]}"
    Rez "${REZ_INCLUDES[@]}" -useDF -o "$RESOURCES_DIR/Resources.rsrc" "${RSRC_SOURCES[@]}"
fi

cat > "$CONTENTS_DIR/Info.plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleExecutable</key>
	<string>$BIN_NAME</string>
	<key>CFBundleIdentifier</key>
	<string>com.retromac.$BIN_NAME</string>
	<key>CFBundleName</key>
	<string>$BIN_NAME</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>LSMinimumSystemVersion</key>
	<string>11.0</string>
	<key>NSHighResolutionCapable</key>
	<true/>
	<key>LSUIElement</key>
	<false/>
</dict>
</plist>
PLIST

# Apple Silicon refuses to launch an unsigned Mach-O binary at all;
# an ad-hoc signature (no identity required) is enough for local use.
codesign --force --deep --sign - "$APP_DIR" >/dev/null 2>&1 || true

echo "Built $APP_DIR"
